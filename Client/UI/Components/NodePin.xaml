<UserControl x:Class="BayMax.UI.Components.NodePin"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             d:DesignHeight="20" d:DesignWidth="80">

    <StackPanel x:Name="PinContainer" Orientation="Horizontal" VerticalAlignment="Center" Height="20">

        <Ellipse x:Name="PinCircle" 
                 Width="16" Height="16" 
                 Fill="#808080" Stroke="Black" StrokeThickness="1"
                 Cursor="Hand" MouseLeftButtonDown="PinCircle_MouseLeftButtonDown"/>

        <TextBlock x:Name="PinTitle" 
                   Text="Pin" 
                   Foreground="LightGray" 
                   FontSize="10"
                   Margin="5,0,5,0"
                   VerticalAlignment="Center"/>

    </StackPanel>
</UserControl>