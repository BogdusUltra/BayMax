<UserControl x:Class="BayMax.UI.Controls.NodeCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Canvas x:Name="DrawArea" Background="#1E1E1E" ClipToBounds="True" Focusable="True">

        <Canvas.ContextMenu>
            <ContextMenu>
                <MenuItem Header="Добавить элемент интерфейса" Click="AddUINode_Click"/>
                <MenuItem Header="Добавить вычислительный блок" Click="AddLogicNode_Click"/>
            </ContextMenu>
        </Canvas.ContextMenu>

        <Rectangle x:Name="SelectionMarquee"
                   Panel.ZIndex="9999999"
               Visibility="Collapsed"
               StrokeThickness="1"
               Stroke="#00A2FF"
               Fill="#3300A2FF" 
               StrokeDashArray="4 4"
               IsHitTestVisible="False"/>
    </Canvas>
</UserControl>