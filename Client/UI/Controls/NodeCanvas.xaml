<UserControl x:Class="BayMax.UI.Controls.NodeCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Border x:Name="Viewport" ClipToBounds="True" Background="#1E1E1E">

        <Canvas x:Name="DrawArea" Width="100000" Height="100000" Focusable="True" MouseRightButtonDown="OnCanvasRightClick">

            <Canvas.Background>
                <DrawingBrush TileMode="Tile" Viewport="0,0,25,25" ViewportUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <GeometryDrawing>
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,25,25"/>
                            </GeometryDrawing.Geometry>
                            <GeometryDrawing.Pen>
                                <Pen Brush="#2A2A2A" Thickness="1"/>
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Canvas.Background>

            <Canvas.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="CanvasScale" ScaleX="1" ScaleY="1" />
                    <TranslateTransform x:Name="CanvasPan" X="-50000" Y="-50000" />
                </TransformGroup>
            </Canvas.RenderTransform>

            <Rectangle x:Name="SelectionMarquee"
                       Panel.ZIndex="10000"
                       Visibility="Collapsed"
                       StrokeThickness="1"
                       Stroke="#00A2FF"
                       Fill="#3300A2FF" 
                       StrokeDashArray="4 4"
                       IsHitTestVisible="False"/>
        </Canvas>
    </Border>
</UserControl>