<UserControl x:Class="BayMax.UI.Controls.NodeBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" 
             Focusable="True">
    <Border x:Name="NodeBorder" 
        MinWidth="120" MinHeight="70"
        Background="#2D2D30" 
        BorderBrush="#007ACC" 
        BorderThickness="2" 
        CornerRadius="8">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.ColumnSpan="3" Background="#1E1E1E" CornerRadius="5,5,0,0" Padding="8,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">

                        <Button Width="12" Height="12"
                    Cursor="Hand"
                    Margin="0,0,8,0" Click="DeleteNode_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Ellipse Fill="#FF4B4B" />
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Ellipse Fill="Red">
                                                            <Ellipse.Effect>
                                                                <DropShadowEffect BlurRadius="5" Color="Red" ShadowDepth="0" Opacity="0.5"/>
                                                            </Ellipse.Effect>
                                                        </Ellipse>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <ToggleButton x:Name="LockToggle"
                          Width="16" Height="16"
                          Cursor="Hand"
                          Background="Transparent"
                          BorderThickness="0"
                          ToolTip="Заблокировать перемещение">
                            <ToggleButton.Style>
                                <Style TargetType="ToggleButton">
                                    <Setter Property="Content" Value="🔓"/>
                                    <Setter Property="Foreground" Value="#888888"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <TextBlock Text="{TemplateBinding Content}" 
                                               Foreground="{TemplateBinding Foreground}" 
                                               FontFamily="Segoe UI Emoji"
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center" 
                                               FontSize="12"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="Content" Value="🔒"/>
                                            <Setter Property="Foreground" Value="#FFD700"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ToggleButton.Style>
                        </ToggleButton>

                    </StackPanel>

                    <TextBlock x:Name="NodeTitle" 
                   Grid.Column="1"
                   Text="Нода" 
                   Foreground="White" 
                   FontWeight="Bold"
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"
                   Margin="0,0,12,0"/>
                </Grid>
            </Border>

            <UniformGrid x:Name="InputPinsContainer" 
                 Grid.Row="1" Grid.Column="0" 
                 Columns="1" 
                 Margin="-6,0,0,0"/>

            <ContentControl x:Name="CustomContentContainer"
                    Grid.Row="1" Grid.Column="1"
                    Margin="10,10, 10, 10"
                    VerticalAlignment="Stretch"
                    HorizontalAlignment="Stretch"/>

            <UniformGrid x:Name="OutputPinsContainer" 
                 Grid.Row="1" Grid.Column="2" 
                 Columns="1" 
                 Margin="0,0,-6,0"/>

            <Thumb Grid.Row="1" Grid.ColumnSpan="3"
           Width="15" Height="15"
           HorizontalAlignment="Right"
           VerticalAlignment="Bottom"
           Cursor="SizeNWSE"
           Margin="0,0,2,2"
           DragDelta="ResizeNode_DragDelta">
                <Thumb.Template>
                    <ControlTemplate TargetType="Thumb">
                        <Path Data="M 15,0 L 15,15 L 0,15 Z" Fill="#888888" Opacity="0.5"/>
                    </ControlTemplate>
                </Thumb.Template>
            </Thumb>
        </Grid>
    </Border>
</UserControl>