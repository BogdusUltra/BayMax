<Window x:Class="BayMax.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BayMax"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800">
    <Grid>
        <StackPanel Margin="20">
            <Button Content="🚀 Запустить локальную машину" Height="40" Click="StartLocal_Click" Background="#2D2D2D" Foreground="White"/>

            <Separator Margin="0,10"/>

            <Label Content="Доступные устройства:"/>
            <DockPanel>
                <Button Content="🔄" Width="30" Click="Refresh_Click" DockPanel.Dock="Right"/>
                <ComboBox x:Name="DeviceCombo" ItemsSource="{Binding AvailableDevices}" DisplayMemberPath="DisplayName" Height="30"/>
            </DockPanel>

            <Button x:Name="ConnectButton" Content="Подключиться к выбранному" Height="35" Click="Connect_Click"/>

            <TextBlock x:Name="StatusLabel" Text="Статус: Ожидание" Foreground="Gray" TextAlignment="Center" Margin="0,10"/>

            <GroupBox Header="Системный журнал" Margin="0,10,0,0" Height="300">
                <TextBox x:Name="LogConsole" 
             IsReadOnly="True" 
             Background="#1E1E1E" 
             Foreground="#DCDCDC" 
             FontFamily="Consolas" 
             VerticalScrollBarVisibility="Auto" 
             TextWrapping="Wrap"/>
            </GroupBox>
        </StackPanel>
        
    </Grid>
</Window>
